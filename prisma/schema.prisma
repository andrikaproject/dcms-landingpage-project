generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  BITUNIX
}

enum ApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String
  role          Role           @default(USER)
  
  // Fitur Bitunix
  uuidBitunix   String?        @unique
  statusReview  ApprovalStatus @default(NONE)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model BitunixUser {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  uuidBitunix          String    @unique @map("uuid_bitunix") @db.VarChar(32)
  email                String    @unique @db.VarChar(255)
  name                 String?   @db.VarChar(120)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  role                 String    @default("BITUNIX") @db.VarChar(32)
  bitunixStatus        String    @default("VERIFIED") @map("bitunix_status") @db.VarChar(32)
  amountUsdt           Decimal?  @map("bitunix_deposit_usdt") @db.Decimal(18, 8)
  lastTradeAt          DateTime? @map("last_trade_at")
  bitunixVerifiedAt    DateTime? @map("bitunix_verified_at")
  bitunixLastCheckedAt DateTime? @map("bitunix_last_checked_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("bitunix_users")
}

model LockedSignal {
  id                String    @id @default(cuid())
  userEmail         String    @map("user_email") @db.VarChar(255)
  uuidBitunix       String?   @map("uuid_bitunix") @db.VarChar(32)
  symbol            String    @db.VarChar(32)
  base              String    @db.VarChar(32)
  timeframe         String    @db.VarChar(16)
  bias              String    @db.VarChar(16)
  source            String?   @db.VarChar(32)
  marketType        String    @default("CEX") @map("market_type") @db.VarChar(16)
  entry             Decimal   @db.Decimal(24, 10)
  currentPrice      Decimal   @map("current_price") @db.Decimal(24, 10)
  sl                Decimal?  @db.Decimal(24, 10)
  tp1               Decimal?  @db.Decimal(24, 10)
  tp2               Decimal?  @db.Decimal(24, 10)
  rsi               Decimal?  @db.Decimal(10, 4)
  emaFast           Decimal?  @map("ema_fast") @db.Decimal(24, 10)
  emaSlow           Decimal?  @map("ema_slow") @db.Decimal(24, 10)
  fastPeriod        Int?      @map("fast_period")
  slowPeriod        Int?      @map("slow_period")
  stochK            Decimal?  @map("stoch_k") @db.Decimal(10, 4)
  stochD            Decimal?  @map("stoch_d") @db.Decimal(10, 4)
  riskPercent       Decimal?  @map("risk_percent") @db.Decimal(10, 4)
  rewardPercent     Decimal?  @map("reward_percent") @db.Decimal(10, 4)
  riskReward        Decimal?  @map("risk_reward") @db.Decimal(10, 4)
  sinceEntryPercent Decimal?  @map("since_entry_percent") @db.Decimal(10, 4)
  progressPercent   Decimal?  @map("progress_percent") @db.Decimal(10, 4)
  status            String    @default("ACTIVE") @db.VarChar(16)
  hitAt             DateTime? @map("hit_at")
  lastCheckedAt     DateTime? @map("last_checked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([userEmail, symbol, timeframe, status], name: "locked_signal_identity")
  @@index([userEmail, status])
  @@map("locked_signals")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  email       String    @db.VarChar(255)
  accountType String    @map("account_type") @db.VarChar(16)
  userId      String    @map("user_id") @db.VarChar(64)
  tokenHash   String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
